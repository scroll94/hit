          { name: "if внутри def", easyTask: "Создай check(ammo). Если ammo > 0, выведи fire. Вызови check(3).", hardTask: "Добавь else: если ammo нет, выведи reload. Вызови check(0).", easyStart: "def check(ammo):\n    if ammo > 0:\n        \n\ncheck()", hardStart: "def check(ammo):\n    if ammo > 0:\n        \n    else:\n        \n\ncheck()", easyHint: "def check(ammo):\n    if ammo > 0:\n        print('fire')\n\ncheck(3)", hardHint: "def check(ammo):\n    if ammo > 0:\n        print('fire')\n    else:\n        print('reload')\n\ncheck(0)", checkEasy: code => /def\s+check\s*\(\s*ammo\s*\)\s*:/i.test(code) && /if\s+ammo\s*>\s*0\s*:/i.test(code) && /print\s*\(\s*['\"]fire['\"]\s*\)/i.test(code) && /check\s*\(\s*3\s*\)/i.test(code), checkHard: code => /def\s+check\s*\(\s*ammo\s*\)\s*:/i.test(code) && /if\s+ammo\s*>\s*0\s*:/i.test(code) && /print\s*\(\s*['\"]fire['\"]\s*\)/i.test(code) && /else\s*:/i.test(code) && /print\s*\(\s*['\"]reload['\"]\s*\)/i.test(code) && /check\s*\(\s*0\s*\)/i.test(code) }
        ]
      }
    ];

    const levels = topicGroups.flatMap((group, topicIndex) =>
      group.tasks.map((task, taskIndex) => ({
        ...task,
        title: `Тема ${topicIndex + 1}: ${group.topic} · задание ${taskIndex + 1}`,
        short: group.topic,
        lesson: group.lesson,
        easyRound: {
          time: Math.max(7, 12 - topicIndex - taskIndex * 0.35),
          targets: 5 + taskIndex,
          size: Math.max(42, 62 - topicIndex * 3 - taskIndex * 2)
        },
        hardRound: {
          time: Math.max(5.5, 9 - topicIndex * 0.5 - taskIndex * 0.35),
          targets: 7 + taskIndex,
          size: Math.max(34, 50 - topicIndex * 3 - taskIndex * 2)
        }
      }))
    );

    const state = {
      level: 0,
      difficulty: "easy",
      solved: false,
      wins: new Set(),
      running: false,
      hits: 0,
      shots: 0,
      targetCount: 0,
      timeLeft: 0,
      roundTime: 0,
      timer: null
    };

    const levelList = document.getElementById("levelList");
    const stats = document.getElementById("stats");
    const lessonTitle = document.getElementById("lessonTitle");
    const lessonText = document.getElementById("lessonText");
    const taskText = document.getElementById("taskText");
    const hintText = document.getElementById("hintText");
    const codeInput = document.getElementById("codeInput");
    const resultText = document.getElementById("resultText");
    const range = document.getElementById("range");
    const rangeMessage = document.getElementById("rangeMessage");
    const timeText = document.getElementById("timeText");
    const targetText = document.getElementById("targetText");
    const accuracyText = document.getElementById("accuracyText");
    const timerFill = document.getElementById("timerFill");
    const startBtn = document.getElementById("startBtn");
    const crosshair = document.getElementById("crosshair");

    function roundSettings() {
      const level = levels[state.level];
      return state.difficulty === "easy" ? level.easyRound : level.hardRound;
    }

    function normalize(code) {
      return code.replace(/\r/g, "").trim();
    }

    function stopRound() {
      state.running = false;
      clearInterval(state.timer);
      range.querySelectorAll(".target").forEach(target => target.remove());
    }

    function selectLevel(index) {
      stopRound();
      state.level = index;
      state.solved = false;
      const level = levels[index];
      lessonTitle.textContent = level.title;
      lessonText.textContent = level.lesson;
      taskText.textContent = state.difficulty === "easy" ? level.easyTask : level.hardTask;
      hintText.textContent = "Сначала попробуй сам. Подсказка появится по кнопке.";
      codeInput.value = state.difficulty === "easy" ? level.easyStart : level.hardStart;
      resultText.className = "result";
      resultText.textContent = "Напиши решение и нажми “Проверить код”.";
      startBtn.disabled = true;
      setMessage("Тир закрыт", "Правильный код откроет раунд. После запуска кликай по мишеням до конца таймера.");
      resetHud();
      renderLevels();
      renderStats();
    }

    function resetHud() {
      const settings = roundSettings();
      state.hits = 0;
      state.shots = 0;
      state.targetCount = settings.targets;
      state.timeLeft = settings.time;
      state.roundTime = settings.time;
      updateHud();
    }

    function updateHud() {
      timeText.textContent = state.timeLeft.toFixed(1);
      targetText.textContent = `${state.hits}/${state.targetCount}`;
      const accuracy = state.shots === 0 ? 100 : Math.round((state.hits / state.shots) * 100);
      accuracyText.textContent = `${accuracy}%`;
      const width = state.roundTime ? Math.max(0, (state.timeLeft / state.roundTime) * 100) : 100;
      timerFill.style.width = `${width}%`;
    }

    function setMessage(title, text, hidden = false) {
      rangeMessage.hidden = hidden;
      rangeMessage.innerHTML = `<strong>${title}</strong><span>${text}</span>`;
    }

    function renderLevels() {
      levelList.innerHTML = "";
      levels.forEach((level, index) => {
        const button = document.createElement("button");
        const done = state.wins.has(keyFor(index));
        const topicNumber = Math.floor(index / 5) + 1;
        const taskNumber = (index % 5) + 1;
        button.className = `level-card${index === state.level ? " active" : ""}${done ? " done" : ""}`;
        button.type = "button";
        button.innerHTML = `
          <span class="level-num">${index + 1}</span>
          <span>
            <span class="level-name">Тема ${topicNumber}: ${level.short}</span>
            <span class="level-state">Задание ${taskNumber}: ${level.name} · ${done ? "пройдено" : index === state.level ? "текущее" : "не пройдено"}</span>
          </span>
        `;
        button.addEventListener("click", () => selectLevel(index));
        levelList.appendChild(button);
      });
    }

    function renderStats() {
      const passed = levels.filter((_, index) => state.wins.has(keyFor(index))).length;
      const settings = roundSettings();
      stats.innerHTML = `
        <span class="pill">Прогресс: ${passed}/${levels.length}</span>
        <span class="pill">Раунд: ${settings.time} сек</span>
        <span class="pill">Цель: ${settings.targets} миш.</span>
      `;
    }

    function keyFor(index = state.level) {
      return `${state.difficulty}-${index}`;
    }

    function checkCode() {
      const level = levels[state.level];
      const code = normalize(codeInput.value);
      const ok = state.difficulty === "easy" ? level.checkEasy(code) : level.checkHard(code);

      if (!ok) {
        state.solved = false;
        startBtn.disabled = true;
        resultText.className = "result bad";
        resultText.textContent = "Код пока не проходит проверку. Проверь кавычки, скобки, имена переменных и отступы.";
        setMessage("Допуск не получен", "Исправь код, затем снова нажми “Проверить код”.");
        return;
      }

      state.solved = true;
      startBtn.disabled = false;
      resultText.className = "result good";
      resultText.textContent = "Код верный. Теперь запускай тир и сбивай мишени до конца таймера.";
      setMessage("Раунд готов", "Нажми “Начать тир”. Мишени появляются в разных точках, промахи портят точность.");
    }

    function startRound() {
      if (!state.solved || state.running) return;
      stopRound();
      resetHud();
      state.running = true;
      startBtn.disabled = true;
      setMessage("", "", true);
      spawnTargets();
      updateHud();

      state.timer = setInterval(() => {
        state.timeLeft = Math.max(0, state.timeLeft - 0.1);
        updateHud();
        if (state.timeLeft <= 0) finishRound(false);
      }, 100);
    }

    function spawnTargets() {
      const settings = roundSettings();
      for (let index = 0; index < settings.targets; index += 1) {
        const target = document.createElement("button");
        target.type = "button";
        target.className = "target";
        target.style.setProperty("--size", `${settings.size}px`);
        target.style.setProperty("--speed", `${700 + Math.random() * 650}ms`);
        target.style.setProperty("--x", `${34 + Math.random() * 54}%`);
        target.style.setProperty("--y", `${26 + Math.random() * 43}%`);
        target.setAttribute("aria-label", "Мишень");
        target.addEventListener("click", event => {
          event.stopPropagation();
          hitTarget(target);
        });
        range.appendChild(target);
      }
    }

    function hitTarget(target) {
      if (!state.running || target.classList.contains("hit")) return;
      state.hits += 1;
      state.shots += 1;
      target.classList.add("hit");
      updateHud();
      setTimeout(() => target.remove(), 260);
      if (state.hits >= state.targetCount) finishRound(true);
    }

    function missShot() {
      if (!state.running) return;
      state.shots += 1;
      updateHud();
    }

    function finishRound(win) {
      const accuracy = state.shots === 0 ? 0 : Math.round((state.hits / state.shots) * 100);
      stopRound();
      startBtn.disabled = false;

      if (win) {
        state.wins.add(keyFor());
        resultText.className = "result good";
        resultText.textContent = `Уровень пройден: ${state.hits}/${state.targetCount}, точность ${accuracy}%. Можно переходить дальше.`;
        setMessage("Уровень пройден", "Хорошая работа. Следующий уровень уже доступен в списке или по кнопке “Дальше”.");
      } else {
        resultText.className = "result bad";
        resultText.textContent = `Время вышло: сбито ${state.hits}/${state.targetCount}. Код верный, но тир нужно пройти быстрее.`;
        setMessage("Время вышло", "Запусти тир ещё раз. Код переписывать не нужно, если проверка уже пройдена.");
      }

      renderLevels();
      renderStats();
      updateHud();
    }

    document.querySelectorAll("[data-difficulty]").forEach(button => {
      button.addEventListener("click", () => {
        document.querySelectorAll("[data-difficulty]").forEach(item => item.classList.remove("active"));
        button.classList.add("active");
        state.difficulty = button.dataset.difficulty;
        selectLevel(state.level);
      });
    });

    document.getElementById("checkBtn").addEventListener("click", checkCode);
    document.getElementById("startBtn").addEventListener("click", startRound);
    document.getElementById("hintBtn").addEventListener("click", () => {
      const level = levels[state.level];
      hintText.textContent = state.difficulty === "easy" ? level.easyHint : level.hardHint;
    });
    document.getElementById("templateBtn").addEventListener("click", () => {
      const level = levels[state.level];
      codeInput.value = state.difficulty === "easy" ? level.easyStart : level.hardStart;
      state.solved = false;
      startBtn.disabled = true;
      resultText.className = "result";
      resultText.textContent = "Шаблон вставлен. Заполни пропуски и проверь код.";
    });
    document.getElementById("prevBtn").addEventListener("click", () => {
      selectLevel((state.level - 1 + levels.length) % levels.length);
    });
    document.getElementById("nextBtn").addEventListener("click", () => {
      selectLevel((state.level + 1) % levels.length);
    });

    range.addEventListener("click", missShot);
    range.addEventListener("mousemove", event => {
      const rect = range.getBoundingClientRect();
      crosshair.style.left = `${event.clientX - rect.left}px`;
      crosshair.style.top = `${event.clientY - rect.top}px`;
    });

    codeInput.addEventListener("keydown", event => {
      if (event.key === "Tab") {
        event.preventDefault();
        const start = codeInput.selectionStart;
        const end = codeInput.selectionEnd;
        codeInput.value = codeInput.value.slice(0, start) + "    " + codeInput.value.slice(end);
        codeInput.selectionStart = codeInput.selectionEnd = start + 4;
      }
    });

    selectLevel(0);
  </script>
</body>
