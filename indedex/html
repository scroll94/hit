<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Python Target Arena</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #111722;
      --panel: #18212f;
      --panel-soft: #202c3d;
      --panel-bright: #28384d;
      --text: #fff8df;
      --muted: #bdc7d6;
      --line: #3c4f68;
      --gold: #ffd166;
      --green: #70e39b;
      --red: #ff6b6b;
      --blue: #62b6ff;
      --cyan: #67e8f9;
      --violet: #c29bff;
      --ground: #4c6f4f;
      --dark: #090d14;
      --shadow: rgba(0, 0, 0, 0.34);
      font-family: "Segoe UI", Arial, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      background:
        radial-gradient(circle at 18% 10%, rgba(98, 182, 255, 0.22), transparent 28%),
        radial-gradient(circle at 76% 4%, rgba(194, 155, 255, 0.16), transparent 24%),
        linear-gradient(180deg, #121a28 0%, #0d131d 100%);
    }

    button,
    textarea {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
      color: inherit;
    }

    .app {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr;
    }

    .topbar {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) auto auto;
      gap: 18px;
      align-items: center;
      padding: 16px 22px;
      background: rgba(12, 18, 28, 0.86);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .brand h1 {
      margin: 0;
      font-size: clamp(22px, 3vw, 34px);
      letter-spacing: 0;
      color: var(--gold);
      text-shadow: 3px 3px 0 #000;
    }

    .brand p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 14px;
    }

    .segmented {
      display: inline-grid;
      grid-template-columns: 1fr 1fr;
      padding: 4px;
      gap: 4px;
      background: var(--dark);
      border: 1px solid var(--line);
      border-radius: 8px;
    }

    .segmented button {
      min-height: 36px;
      padding: 0 14px;
      border-radius: 6px;
      background: transparent;
      color: var(--muted);
    }

    .segmented button.active {
      background: var(--blue);
      color: #07101a;
      font-weight: 700;
    }

    .stats {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: end;
    }

    .pill {
      min-height: 36px;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 11px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(32, 44, 61, 0.85);
      color: var(--muted);
      white-space: nowrap;
    }

    .layout {
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      min-height: 0;
    }

    .levels {
      padding: 18px;
      background: rgba(13, 19, 29, 0.72);
      border-right: 1px solid rgba(255, 255, 255, 0.08);
      overflow: auto;
    }

    .levels h2,
    .panel-title {
      margin: 0 0 12px;
      font-size: 15px;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .level-list {
      display: grid;
      gap: 10px;
    }

    .level-card {
      width: 100%;
      min-height: 74px;
      padding: 12px;
      display: grid;
      grid-template-columns: 38px 1fr;
      gap: 10px;
      align-items: center;
      text-align: left;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.18);
    }

    .level-card.active {
      border-color: var(--blue);
      background: linear-gradient(135deg, #213856, #1d2d40);
    }

    .level-card.done {
      border-color: rgba(112, 227, 155, 0.75);
    }

    .level-num {
      width: 38px;
      height: 38px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: var(--dark);
      color: var(--gold);
      font-weight: 800;
      box-shadow: inset -3px -3px 0 rgba(255,255,255,0.05);
    }

    .level-name {
      display: block;
      font-weight: 700;
      margin-bottom: 5px;
    }

    .level-state {
      color: var(--muted);
      font-size: 13px;
    }

    .content {
      min-width: 0;
      padding: 18px;
      display: grid;
      grid-template-rows: minmax(360px, 48vh) minmax(330px, 1fr);
      gap: 18px;
    }

    .range {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      background:
        linear-gradient(180deg, #65b9e9 0 45%, #5d9163 45% 62%, #4f3d31 62% 100%);
      box-shadow: 0 18px 34px rgba(0, 0, 0, 0.28);
      cursor: crosshair;
      user-select: none;
    }

    .range::before {
      content: "";
      position: absolute;
      inset: 0;
      opacity: 0.24;
      background:
        linear-gradient(90deg, rgba(255,255,255,0.24) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255,255,255,0.18) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
    }

    .mountain {
      position: absolute;
      bottom: 38%;
      left: 4%;
      width: 210px;
      height: 76px;
      background: #467459;
      clip-path: polygon(0 100%, 30% 24%, 54% 70%, 76% 10%, 100% 100%);
      opacity: 0.82;
    }

    .tower {
      position: absolute;
      right: 5%;
      bottom: 37%;
      width: 72px;
      height: 118px;
      background: #6f5a4c;
      border: 4px solid #2b211d;
      box-shadow: inset -12px 0 0 rgba(0, 0, 0, 0.15);
    }

    .tower::before {
      content: "";
      position: absolute;
      left: -13px;
      top: -26px;
      width: 92px;
      height: 28px;
      background: #7f453a;
      border: 4px solid #2b211d;
    }

    .range-hud {
      position: absolute;
      inset: 14px 14px auto 14px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      z-index: 2;
      pointer-events: none;
    }

    .hud-box {
      padding: 10px 12px;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 8px;
      background: rgba(9, 13, 20, 0.76);
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.22);
    }

    .hud-label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 4px;
    }

    .hud-value {
      font-size: clamp(20px, 3vw, 30px);
      font-weight: 800;
      color: var(--text);
    }

    .timer-bar {
      position: absolute;
      left: 14px;
      right: 14px;
      top: 100px;
      z-index: 2;
      height: 10px;
      border-radius: 999px;
      background: rgba(9, 13, 20, 0.7);
      overflow: hidden;
      pointer-events: none;
    }

    .timer-fill {
      height: 100%;
      width: 100%;
      background: linear-gradient(90deg, var(--green), var(--gold), var(--red));
      transition: width 160ms linear;
    }

    .rifle {
      position: absolute;
      left: 7%;
      bottom: 17%;
      width: 220px;
      height: 86px;
      z-index: 1;
      filter: drop-shadow(10px 12px 0 rgba(0, 0, 0, 0.26));
      transform-origin: left center;
      animation: aim 1200ms ease-in-out infinite;
    }

    .rifle::before {
      content: "";
      position: absolute;
      left: 8px;
      top: 36px;
      width: 178px;
      height: 16px;
      border-radius: 4px;
      background: linear-gradient(90deg, #7a4d2d 0 28%, #b57942 28% 48%, #2f3945 48% 100%);
      border: 3px solid #111722;
      box-shadow:
        150px -6px 0 -2px #9aa7b4,
        174px -6px 0 -2px #d8e0e8,
        52px -19px 0 -4px #1d2632,
        78px -20px 0 -5px #1d2632,
        64px 19px 0 -3px #3f2c20,
        72px 36px 0 -5px #3f2c20;
    }

    .rifle::after {
      content: "";
      position: absolute;
      left: 104px;
      top: 18px;
      width: 38px;
      height: 16px;
      border: 3px solid #111722;
      border-radius: 999px 999px 3px 3px;
      background: #222d3a;
      box-shadow:
        -86px 26px 0 8px #5c3925,
        -96px 34px 0 2px #111722,
        23px 20px 0 -2px #151d27,
        34px 24px 0 -4px #151d27,
        76px 44px 0 -5px #151d27,
        98px 44px 0 -5px #151d27;
    }

    .target {
      position: absolute;
      width: var(--size);
      height: var(--size);
      left: var(--x);
      top: var(--y);
      z-index: 3;
      border-radius: 50%;
      background:
        radial-gradient(circle, #fff8df 0 18%, #ff6b6b 18% 34%, #fff8df 34% 50%, #3a86ff 50% 67%, #111722 67% 100%);
      border: 4px solid #090d14;
      box-shadow: 0 8px 0 rgba(0, 0, 0, 0.24);
      transform: translate(-50%, -50%);
      animation: bob var(--speed) steps(4) infinite alternate;
    }

    .target::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: calc(-1 * var(--size) * 0.8);
      width: 7px;
      height: calc(var(--size) * 0.86);
      background: #3f2f25;
      transform: translateX(-50%);
      z-index: -1;
    }

    .target.hit {
      pointer-events: none;
      animation: fall 260ms steps(4) forwards;
    }

    .crosshair {
      position: absolute;
      width: 38px;
      height: 38px;
      margin: -19px 0 0 -19px;
      border: 2px solid rgba(255, 248, 223, 0.86);
      border-radius: 50%;
      pointer-events: none;
      z-index: 5;
      display: none;
    }

    .crosshair::before,
    .crosshair::after {
      content: "";
      position: absolute;
      background: rgba(255, 248, 223, 0.86);
    }

    .crosshair::before {
      width: 50px;
      height: 2px;
      left: -8px;
      top: 17px;
    }

    .crosshair::after {
      width: 2px;
      height: 50px;
      left: 17px;
      top: -8px;
    }

    .range:hover .crosshair {
      display: block;
    }

    .message {
      position: absolute;
      left: 50%;
      top: 54%;
      z-index: 4;
      width: min(520px, calc(100% - 32px));
      padding: 18px;
      transform: translate(-50%, -50%);
      text-align: center;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 8px;
      background: rgba(9, 13, 20, 0.82);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
    }

    .message strong {
      display: block;
      color: var(--gold);
      font-size: 22px;
      margin-bottom: 7px;
    }

    .message span {
      color: var(--muted);
      line-height: 1.5;
    }

    .workbench {
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(260px, 390px) minmax(0, 1fr);
      gap: 18px;
    }

    .card {
      min-width: 0;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      background: rgba(24, 33, 47, 0.94);
      box-shadow: 0 16px 30px rgba(0, 0, 0, 0.22);
    }

    .lesson {
      padding: 16px;
      overflow: auto;
    }

    .lesson h2 {
      margin: 0 0 10px;
      color: var(--text);
      font-size: 23px;
    }

    .lesson p {
      margin: 0 0 12px;
      color: var(--muted);
      line-height: 1.55;
    }

    .task-box {
      margin: 14px 0;
      padding: 13px;
      border-radius: 8px;
      background: #101722;
      border: 1px solid var(--line);
    }

    .task-box strong {
      display: block;
      color: var(--green);
      margin-bottom: 6px;
    }

    .hint {
      margin: 0;
      padding: 12px;
      min-height: 82px;
      border-radius: 8px;
      background: #0a0f17;
      border: 1px solid var(--line);
      color: #dff6ff;
      line-height: 1.5;
      overflow: auto;
    }

    .editor {
      display: grid;
      grid-template-rows: auto minmax(160px, 1fr) auto auto;
      gap: 12px;
      padding: 16px;
    }

    .editor-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .editor-header h2 {
      margin: 0;
      font-size: 21px;
    }

    .code-tools {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: end;
    }

    textarea {
      width: 100%;
      min-height: 180px;
      resize: vertical;
      border: 1px solid #49647f;
      border-radius: 8px;
      padding: 14px;
      color: #e6fbff;
      background: #080d14;
      outline: none;
      line-height: 1.55;
      tab-size: 4;
      font-family: Consolas, "Courier New", monospace;
      font-size: 15px;
    }

    textarea:focus {
      border-color: var(--cyan);
      box-shadow: 0 0 0 3px rgba(103, 232, 249, 0.16);
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .btn {
      min-height: 42px;
      padding: 0 15px;
      border-radius: 8px;
      background: var(--panel-bright);
      border: 1px solid var(--line);
      font-weight: 700;
      transition: transform 120ms ease, filter 120ms ease, background 120ms ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      filter: brightness(1.08);
    }

    .btn.primary {
      background: var(--green);
      color: #06120c;
      border-color: transparent;
    }

    .btn.start {
      background: var(--gold);
      color: #1b1300;
      border-color: transparent;
    }

    .btn:disabled {
      cursor: not-allowed;
      opacity: 0.55;
      transform: none;
      filter: none;
    }

    .result {
      min-height: 52px;
      padding: 12px 13px;
      border-radius: 8px;
      border: 1px solid var(--line);
      background: #101722;
      color: var(--muted);
      line-height: 1.45;
    }

    .result.good {
      border-color: rgba(112, 227, 155, 0.72);
      color: var(--green);
    }

    .result.bad {
      border-color: rgba(255, 107, 107, 0.72);
      color: var(--red);
    }

    @keyframes aim {
      50% { transform: translateY(-3px) rotate(-1deg); }
    }

    @keyframes bob {
      from { transform: translate(-50%, -50%) translateY(-8px); }
      to { transform: translate(-50%, -50%) translateY(8px); }
    }

    @keyframes fall {
      to {
        opacity: 0;
        transform: translate(-50%, -50%) translateY(35px) rotate(18deg) scale(0.8);
      }
    }

    @media (max-width: 980px) {
      .topbar {
        grid-template-columns: 1fr;
      }

      .stats {
        justify-content: start;
      }

      .layout {
        grid-template-columns: 1fr;
      }

      .levels {
        border-right: 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .level-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .content {
        grid-template-rows: 360px auto;
      }

      .workbench {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 620px) {
      .topbar,
      .levels,
      .content {
        padding: 12px;
      }

      .level-list,
      .range-hud {
        grid-template-columns: 1fr;
      }

      .timer-bar {
        top: 218px;
      }

      .rifle {
        left: 1%;
        transform: scale(0.78);
        transform-origin: bottom left;
      }

      .editor-header {
        align-items: start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <h1>Python Target Arena</h1>
      <p>Выбери тему Python, реши задание, затем пройди короткий тир на время.</p>
      </div>
      <div class="segmented" aria-label="Выбор сложности">
        <button class="active" type="button" data-difficulty="easy">Простая</button>
        <button type="button" data-difficulty="hard">Сложная</button>
      </div>
      <div class="stats" id="stats"></div>
    </header>

    <div class="layout">
      <aside class="levels">
        <h2>Темы Python</h2>
        <div class="level-list" id="levelList"></div>
      </aside>

      <main class="content">
        <section class="range" id="range" aria-label="Тир с мишенями">
          <div class="mountain"></div>
          <div class="tower"></div>
          <div class="range-hud">
            <div class="hud-box">
              <span class="hud-label">Время</span>
              <span class="hud-value" id="timeText">0.0</span>
            </div>
            <div class="hud-box">
              <span class="hud-label">Мишени</span>
              <span class="hud-value" id="targetText">0/0</span>
            </div>
            <div class="hud-box">
              <span class="hud-label">Точность</span>
              <span class="hud-value" id="accuracyText">100%</span>
            </div>
          </div>
          <div class="timer-bar"><div class="timer-fill" id="timerFill"></div></div>
          <div class="rifle" aria-hidden="true"></div>
          <div class="crosshair" id="crosshair"></div>
          <div class="message" id="rangeMessage">
            <strong>Тир закрыт</strong>
            <span>Проверь код. Если ответ верный, кнопка запуска откроет раунд с мишенями.</span>
          </div>
        </section>

        <section class="workbench">
          <article class="card lesson">
            <h2 id="lessonTitle"></h2>
            <p id="lessonText"></p>
            <div class="task-box">
              <strong>Задание для допуска</strong>
              <span id="taskText"></span>
            </div>
            <h3 class="panel-title">Подсказка</h3>
            <pre class="hint" id="hintText"></pre>
          </article>

          <section class="card editor">
            <div class="editor-header">
              <h2>Редактор кода</h2>
              <div class="code-tools">
                <button class="btn" type="button" id="templateBtn">Шаблон</button>
                <button class="btn" type="button" id="hintBtn">Показать подсказку</button>
              </div>
            </div>
            <textarea id="codeInput" spellcheck="false"></textarea>
            <div class="actions">
              <button class="btn primary" type="button" id="checkBtn">Проверить код</button>
              <button class="btn start" type="button" id="startBtn" disabled>Начать тир</button>
              <button class="btn" type="button" id="prevBtn">Назад</button>
              <button class="btn" type="button" id="nextBtn">Дальше</button>
            </div>
            <div class="result" id="resultText">Напиши решение и нажми “Проверить код”.</div>
          </section>
        </section>
      </main>
    </div>
  </div>

  <script>
    const oldLevels = [
      {
        title: "Тема 1: print",
        short: "print",
        lesson: "print() выводит текст. В учебной арене это команда, которая заряжает винтовку.",
        easyTask: "Выведи слово hit.",
        hardTask: "Выведи hit, затем reload на следующей строке.",
        easyStart: "print('')",
        hardStart: "print('')\nprint('')",
        easyHint: "print('hit')",
        hardHint: "print('hit')\nprint('reload')",
        checkEasy: code => /print\s*\(\s*["']hit["']\s*\)/i.test(code),
        checkHard: code => /print\s*\(\s*["']hit["']\s*\)/i.test(code) && /print\s*\(\s*["']reload["']\s*\)/i.test(code),
        easyRound: { time: 12, targets: 5, size: 62 },
        hardRound: { time: 9, targets: 7, size: 50 }
      },
      {
        title: "Тема 2: переменные",
        short: "variables",
        lesson: "Переменная хранит значение. Так можно сохранить команду атаки или количество патронов.",
        easyTask: "Создай attack = 'hit' и выведи attack.",
        hardTask: "Создай attack = 'hit' и ammo = 3, затем выведи обе переменные.",
        easyStart: "attack = ''\nprint()",
        hardStart: "attack = ''\nammo = 0\nprint()\nprint()",
        easyHint: "attack = 'hit'\nprint(attack)",
        hardHint: "attack = 'hit'\nammo = 3\nprint(attack)\nprint(ammo)",
        checkEasy: code => /attack\s*=\s*["']hit["']/i.test(code) && /print\s*\(\s*attack\s*\)/i.test(code),
        checkHard: code => /attack\s*=\s*["']hit["']/i.test(code) && /ammo\s*=\s*3\b/i.test(code) && /print\s*\(\s*attack\s*\)/i.test(code) && /print\s*\(\s*ammo\s*\)/i.test(code),
        easyRound: { time: 11, targets: 6, size: 58 },
        hardRound: { time: 8, targets: 8, size: 46 }
      },
      {
        title: "Тема 3: input",
        short: "input",
        lesson: "input() получает текст от игрока. Его обычно кладут в переменную, чтобы использовать дальше.",
        easyTask: "Получи имя игрока через input() и сохрани в name.",
        hardTask: "Получи command через input(). Если игрок ввел команду, выведи command.",
        easyStart: "name = input('')",
        hardStart: "command = input('')\nprint()",
        easyHint: "name = input('Имя: ')",
        hardHint: "command = input('Команда: ')\nprint(command)",
